# ============================================================
# 后端服务环境变量
# 复制本文件为 .env，填入真实值后启动 server.py
# ============================================================

# ---- LLM（SiliconFlow 兼容 OpenAI 接口）----
API_KEY=sk-dtqnvyciikipleclahlrrcjogyxgqntdtgmjjwnqskiwtren

# ---- Azure AI Speech（TTS / ASR）----
# 在 Azure Portal 中找到「语音」资源 → 密钥和终结点
# 区域示例：eastasia / eastus / southeastasia
AZURE_SPEECH_KEY=8uvVjZM7CJNf9HJI9qyGFpKAxBwvTwYKoMLdDC4NZbRFSxQqlaIFJQQJ99CDACqBBLyXJ3w3AAAYACOGQ8C8
AZURE_SPEECH_REGION=southeastasia

# ---- LLM 接口配置 ----
LLM_API_URL=https://api.siliconflow.cn/v1/chat/completions
LLM_MODEL=Pro/Qwen/Qwen2.5-7B-Instruct

# ---- 服务器配置 ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---- SoulX-FlashHead 视频生成配置 ----
# 克隆到项目根目录后无需改动：
#   git clone https://github.com/Soul-AILab/SoulX-FlashHead
# lite（单卡实时）或 pro（需双卡 RTX5090）
FLASHHEAD_MODEL_TYPE=lite

# ---- 天气 MCP（modelscope 托管，SSE 传输）----
# 默认值已写在 tools.py 中，下面这行只在需要换服务器时启用
# WEATHER_MCP_URL=https://mcp.api-inference.modelscope.net/fd58fbe7964240/sse

# ---- 默认天气查询城市 ----
# 中文城市名即可，例如 "北京" "上海" "广州"
# DEFAULT_CITY=北京

# ---- 新闻 MCP（Bing CN，streamable_http 传输）----
# 优先走此 MCP；若失败自动回退到 RSS 抓取（免费、无需 Key）
NEWS_MCP_URL=https://mcp.api-inference.modelscope.net/20a59a76221144/mcp
