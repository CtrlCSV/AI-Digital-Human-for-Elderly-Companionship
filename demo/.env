# ============================================================
# 后端服务环境变量
# 新机器首次运行前请复制/保留本文件，并填写自己的 API 密钥。
# 路径均使用相对路径，项目移动到其他目录后无需修改。
# ============================================================

# ---- LLM：SiliconFlow 或其他 OpenAI 兼容接口 ----
# 必填。用于生成聊天回复。
API_KEY=sk-dtqnvyciikipleclahlrrcjogyxgqntdtgmjjwnqskiwtren

# ---- Azure AI Speech：TTS 语音合成 ----
# 必填。用于生成数字人的回复声音。
# 区域示例：southeastasia / eastasia / eastus
AZURE_SPEECH_KEY=8uvVjZM7CJNf9HJI9qyGFpKAxBwvTwYKoMLdDC4NZbRFSxQqlaIFJQQJ99CDACqBBLyXJ3w3AAAYACOGQ8C8
AZURE_SPEECH_REGION=southeastasia

# ---- LLM 接口配置 ----
LLM_API_URL=https://api.siliconflow.cn/v1/chat/completions
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# ---- 服务器配置 ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---- SoulX-FlashHead 视频生成配置 ----
# 克隆到项目根目录后无需改动：
#   git clone https://github.com/Soul-AILab/SoulX-FlashHead
# lite（单卡实时）或 pro（需双卡 RTX5090）
FLASHHEAD_ENABLED=1
FLASHHEAD_MODEL_TYPE=lite
FLASHHEAD_REPO_DIR=D:\GREYCRANE\proj\SoulX-FlashHead\SoulX-FlashHead-main
FLASHHEAD_CKPT_DIR=D:\GREYCRANE\proj\SoulX-FlashHead\models\SoulX-FlashHead-1_3B
FLASHHEAD_WAV2VEC_DIR=D:\GREYCRANE\proj\SoulX-FlashHead\models\wav2vec2-base-960h
FLASHHEAD_DISABLE_TORCH_COMPILE=1

# ---- 天气 MCP（modelscope 托管，SSE 传输）----
# 默认值已写在 tools.py 中，下面这行只在需要换服务器时启用
# WEATHER_MCP_URL=https://mcp.api-inference.modelscope.net/fd58fbe7964240/sse

# ---- 默认天气查询城市 ----
# 中文城市名即可，例如 "北京" "上海" "广州"
# DEFAULT_CITY=北京

# ---- 新闻 MCP（Bing CN，streamable_http 传输）----
# 优先走此 MCP；若失败自动回退到 RSS 抓取（免费、无需 Key）
NEWS_MCP_URL=https://mcp.api-inference.modelscope.net/20a59a76221144/mcp

# ---- ASR 语音识别配置 ----
ASR_MODEL_ID=FunAudioLLM/SenseVoiceSmall
ASR_MODEL_PATH=D:/ai_models/SenseVoiceSmall
ASR_LANGUAGE=auto
ASR_DEVICE=auto

# ---- FlashHead remote (Colab GPU) ----
# Set this to the public URL printed by colab_flashhead_server.py on Colab
# (cloudflared / ngrok). When set, all video generation runs on the cloud GPU
# and this machine needs no torch / model weights. Leave empty to run locally.
FLASHHEAD_REMOTE_URL=http://localhost:9000
FLASHHEAD_REMOTE_TIMEOUT=900

# ---- 数据与缓存 ----
VECTOR_DB_PATH=%LOCALAPPDATA%\c4proj\vector_db

# 国内网络可改为：https://hf-mirror.com
HF_ENDPOINT=https://huggingface.co
