# ============================================================
# ModelScope Notebook 环境变量示例
# 使用时复制为 demo/.env，并填写自己的密钥。
# ============================================================

# ---- LLM：SiliconFlow 或其他 OpenAI 兼容接口 ----
API_KEY=
LLM_API_URL=https://api.siliconflow.cn/v1/chat/completions
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# ---- Azure AI Speech：TTS 语音合成 ----
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia

# ---- 服务启动配置 ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---- ASR：SenseVoiceSmall 语音识别 ----
ASR_MODEL_ID=FunAudioLLM/SenseVoiceSmall
ASR_MODEL_PATH=models/SenseVoiceSmall
ASR_LANGUAGE=auto
ASR_DEVICE=auto

# ---- SoulX-FlashHead：Notebook 中保持相对路径 ----
FLASHHEAD_ENABLED=1
FLASHHEAD_MODEL_TYPE=lite
FLASHHEAD_REPO_DIR=../SoulX-FlashHead
FLASHHEAD_CKPT_DIR=../SoulX-FlashHead/models/SoulX-FlashHead-1_3B
FLASHHEAD_WAV2VEC_DIR=../SoulX-FlashHead/models/wav2vec2-base-960h
FLASHHEAD_DISABLE_TORCH_COMPILE=1

# ---- 数据与缓存 ----
VECTOR_DB_PATH=vector_db
HF_ENDPOINT=https://hf-mirror.com

# ---- 可选 MCP 服务 ----
# WEATHER_MCP_URL=
# NEWS_MCP_URL=
